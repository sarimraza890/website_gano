SECRET_KEY=replace-this-secret
DEBUG=False
ALLOWED_HOSTS=your-domain.com,www.your-domain.com
CSRF_TRUSTED_ORIGINS=https://your-domain.com,https://www.your-domain.com
DATABASE_URL=postgresql://user:password@host:5432/database

# Supabase S3 Storage Settings (Optional - fallback to local storage if not provided)
SUPABASE_AWS_ACCESS_KEY_ID=your-s3-access-key-id
SUPABASE_AWS_SECRET_ACCESS_KEY=your-s3-secret-access-key
SUPABASE_STORAGE_BUCKET_NAME=radiographs
SUPABASE_AWS_REGION=ap-northeast-1
SUPABASE_S3_ENDPOINT_URL=https://your-project-id.storage.supabase.co/storage/v1/s3
